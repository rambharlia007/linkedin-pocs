# Copy to .env (gitignored). Do NOT commit real values to this template.

# Required: your API key. Bearer-style. Vendor key, proxy virtual key, or Azure key.
OPENAI_API_KEY=sk-...

# Optional: endpoint URL. Either variable name is accepted.
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_BASE=https://your-resource.services.ai.azure.com/openai/v1
# If the URL ends in "/responses" (Azure Responses API), the script strips it
# automatically and uses /chat/completions.

# Optional: model / deployment name. For Azure, this is the deployment name.
# DEMO_MODEL=claude-sonnet-4-6
# DEMO_MODEL=gpt-5.2
